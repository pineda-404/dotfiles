# Captura Efímera (Toma foto instantánea a memoria y abre el editor para recortar/copiar)
bindsym $mod+s exec grim -g "$(slurp)" - | swappy -f -

# Captura a Archivo (Toma foto instantánea, abres el editor, recortas y al guardar va a Pictures)
# Nota: En swappy configuras la carpeta de guardado por defecto en ~/.config/swappy/config
bindsym $mod+Shift+s exec grim - | swappy -f - -o ~/Pictures/$(date +%Y-%m-%d_%H-%M-%S).png
